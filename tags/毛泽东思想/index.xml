    <item>
      <title>心正方为王道</title>
      <link>https://vanvj00001.github.io/oldvan/posts/zhi-shi-fen-zi-gai-zao-xin-zheng-wang-dao/</link>
      <pubDate>Thu, 02 Apr 2026 14:20:00 +0800</pubDate>
